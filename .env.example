# Vision Affichage — environment variable example
# Copy to `.env` (browser-visible VITE_* vars only) and configure
# Supabase secrets separately for server-side credentials.

# ── Supabase (browser-visible) ─────────────────────────────────────────────
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Toggle SanMar next-gen edge functions (Step 3+ deployment).
# When false (default), the Step 1 client stubs throw a clear
# "not deployed yet" error so UI can be wired ahead of time.
# Flip to true once Step 3 ships /functions/v1/sanmar-* endpoints.
VITE_SANMAR_NEXT_GEN=false

# SanMar Canada PromoStandards (server-side only, never expose to browser)
# Set these via `supabase secrets set` — NOT in this file. They are
# documented here for operators only.
SANMAR_CUSTOMER_ID=
SANMAR_PASSWORD=
SANMAR_MEDIA_PASSWORD=
SANMAR_ENV=UAT
