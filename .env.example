# Vision Affichage — environment variable example
# Copy to `.env` (browser-visible VITE_* vars only) and configure
# Supabase secrets separately for server-side credentials.

# ── Supabase (browser-visible) ─────────────────────────────────────────────
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Toggle SanMar next-gen edge functions.
# Step 3 deployed the 6 /functions/v1/sanmar-* endpoints; Step 4 wired
# the /admin/sanmar dashboard + /suivi/:orderNumber tracking page through
# the client wrapper. Defaults to true so dev environments hit the new
# edge functions immediately. Production deploys can override to false
# while operator credentials are in flight — /admin/sanmar and
# /suivi/:orderNumber both gracefully render an empty/disabled state
# with the gate off, so flipping back to true does NOT brick the routes.
VITE_SANMAR_NEXT_GEN=true

# SanMar Canada PromoStandards (server-side only, never expose to browser)
# Set these via `supabase secrets set` — NOT in this file. They are
# documented here for operators only.
SANMAR_CUSTOMER_ID=
SANMAR_PASSWORD=
SANMAR_MEDIA_PASSWORD=
SANMAR_ENV=UAT
