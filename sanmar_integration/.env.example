SANMAR_CUSTOMER_ID=your_customer_id
SANMAR_PASSWORD=your_edi_password
SANMAR_MEDIA_PASSWORD=your_media_password
SANMAR_ENV=uat   # uat | prod
SANMAR_BASE_URL_UAT=https://edi.atc-apparel.com/uat-ws/promostandards/
SANMAR_BASE_URL_PROD=https://edi.atc-apparel.com/pstd/
SANMAR_DB_PATH=./data/sanmar_local.db
SANMAR_CATALOG_XLSX=./data/master_catalog.xlsx

# Optional — Slack/Zapier webhook for sync failure + order transition alerts
SANMAR_ALERT_WEBHOOK_URL=

# Optional — outbound HTTP endpoint for customer-facing order transitions
# (fires on status 60/75/80/99). See docs/SANMAR_WEBHOOKS.md for the
# wire format + HMAC verification recipe.
SANMAR_CUSTOMER_WEBHOOK_URL=
SANMAR_CUSTOMER_WEBHOOK_SECRET=
