<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__logo">
      {% if section.settings.logo %}
        {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name }}
      {% else %}
        <strong>{{ shop.name }}</strong>
      {% endif %}
    </a>
    <nav class="site-header__nav">
      <a href="/collections/all">Boutique</a>
      <a href="/cart" class="site-header__cart">
        Panier{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}
      </a>
    </nav>
  </div>
</header>
<style>
  .site-header { border-bottom: 1px solid #eee; background: #fff; position: sticky; top: 0; z-index: 100; }
  .site-header__inner { max-width: 1100px; margin: 0 auto; padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; }
  .site-header__logo { font-size: 18px; font-weight: 900; color: var(--navy); }
  .site-header__logo img { height: 32px; width: auto; }
  .site-header__nav { display: flex; gap: 20px; font-size: 14px; font-weight: 600; }
  .site-header__cart { background: var(--navy); color: #fff; padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 800; }
</style>
{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" }
  ]
}
{% endschema %}
